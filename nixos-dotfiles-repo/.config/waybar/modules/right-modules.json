{
  "tray": {
    "icon-size": 14,
    "spacing": 2
  },
  "wireplumber": {
    "format": "{volume}% {icon}",
    "format-source-muted": " ",
    "format-icons": {
        "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol"
  },
  "network": {
    "format": "{essid} {signalStrength}%"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  }
}
