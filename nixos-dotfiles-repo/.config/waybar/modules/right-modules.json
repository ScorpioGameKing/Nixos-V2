{
  "tray": {
    "icon-size": 14,
    "spacing": 2
  },
  "wireplumber#source": {
    "node-type": "Audio/Source",
    "format": "{volume}% ≤░Ξυ",
    "format-muted": "≤░Ξφ",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "scroll-step": 5
  },
  "wireplumber": {
    "format": "{volume}% {icon}",
    "format-source-muted": " ",
    "format-icons": {
        "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    }
  },
  "network": {
    "format": "{essid} {signalStrength}%"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  }
}
